# CareerStar environment variables.
# Copy this file to `.env.local` (which is gitignored) and fill in your key.
#
# Get a key at https://console.anthropic.com/  → API Keys.
# This enables the plain-English LLM explanations. Without it, CareerStar
# still works and shows factual notes instead (graceful fallback).
#
# SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_, never commit the real key.

ANTHROPIC_API_KEY=your-key-here
